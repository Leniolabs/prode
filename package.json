{
  "name": "hacker-prode",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build-prod": "./setup.sh && next build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db:up": "docker compose up -d prode-test-db && TEST_DATABASE_URL=\"postgresql://leniolabs:leniolabs@localhost:5433/prode_test\" DATABASE_URL=\"postgresql://leniolabs:leniolabs@localhost:5433/prode_test\" npx prisma db push --skip-generate",
    "test:db:reset": "docker compose rm -sfv prode-test-db && npm run test:db:up",
    "screenshot": "tsx harness/screenshot.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^1.4.1",
    "@napi-rs/canvas": "^0.1.30",
    "@next-auth/prisma-adapter": "^1.0.5",
    "@prisma/client": "^4.5.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/axios": "^0.14.0",
    "@types/fluent-ffmpeg": "^2.1.20",
    "@types/uuid": "^8.3.4",
    "axios": "^1.1.3",
    "fluent-ffmpeg": "^2.1.2",
    "gif-encoder-2": "^1.0.5",
    "next": "13.0.0",
    "next-auth": "^4.15.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sass": "^1.55.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "18.0.23",
    "@types/react-dom": "18.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "8.26.0",
    "eslint-config-next": "13.0.0",
    "playwright": "^1.60.0",
    "prisma": "^4.5.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.3",
    "typescript": "^4.8.4",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  }
}
