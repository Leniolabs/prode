GOOGLE_ID=
GOOGLE_SECRET=
AUTH_SECRET=

DATABASE_URL=postgresql://leniolabs:leniolabs@localhost:5432/prode
RESULTS_PROVIDER=espn
API_SPORTS_KEY=any-api-sports-key
API_SPORTS_BASE_URL=https://v3.football.api-sports.io

# Cron job secret — must match the CRON_SECRET GitHub Actions secret
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Visual regression harness (npm run harness:baseline / harness:check)
# ADMIN_EMAIL: email of a user in the DB with admin privileges — used to capture the /admin route
# HARNESS_USER_EMAIL: email for the regular-user session (defaults to playwright@dev.local)
ADMIN_EMAIL=
HARNESS_USER_EMAIL=
